# Copy this file to .env and fill in your own real values.
# Never commit the actual .env file — it's already excluded via .gitignore.

# MongoDB connection string (MongoDB Atlas or local)
MONGO_URI=your_mongodb_connection_string_here

# Port the backend server runs on
PORT=5000

# A long, random secret string used to sign JWT auth tokens
JWT_SECRET=replace_with_a_long_random_secret

# Google OAuth Client ID (from Google Cloud Console -> APIs & Services -> Credentials)
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# Gmail address used to send verification emails
EMAIL_USER=your_gmail_address_here

# Gmail App Password (NOT your normal Gmail password)
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_PASS=your_gmail_app_password_here